{
  "journey": "cron-taskhub",
  "description": "Cron job management and TaskHub task management within the Monitor tab",
  "baseUrl": "https://mac-mini.tailde842d.ts.net/agent-monitor",
  "credentials": {
    "USER": {
      "username": "admin",
      "password": "${E2E_PASSWORD}",
      "role": "USER"
    }
  },
  "testCases": [
    {
      "id": "CT-01",
      "title": "Navigate to cron sub-tab",
      "description": "User navigates from the root page to the Monitor tab and then opens the Cron sub-tab",
      "steps": [
        {
          "action": "navigate",
          "url": "/agent-monitor/",
          "description": "Start at root (assumes logged in)"
        },
        {
          "action": "click",
          "selector": "[data-dtab='monitor']",
          "description": "Click Monitor tab"
        },
        {
          "action": "waitFor",
          "selector": "[data-tab='cron']",
          "description": "Wait for Cron sub-tab to be visible"
        },
        {
          "action": "click",
          "selector": "[data-tab='cron']",
          "description": "Click Cron sub-tab"
        },
        {
          "action": "waitFor",
          "selector": "#cron-tab, .cron-section, [data-section='cron']",
          "description": "Wait for Cron section to render"
        },
        {
          "action": "screenshot",
          "filename": "CT-01-cron-tab-active.png",
          "description": "Verify Cron sub-tab is active and content is visible"
        }
      ],
      "assertions": [
        {
          "type": "elementVisible",
          "selector": "[data-tab='cron'].active, [data-tab='cron'][aria-selected='true']",
          "description": "Cron sub-tab should be marked active"
        }
      ]
    },
    {
      "id": "CT-02",
      "title": "Cron job list loads",
      "description": "The Cron section fetches and displays the list of cron jobs from GET /api/cron/jobs",
      "steps": [
        {
          "action": "navigate",
          "url": "/agent-monitor/",
          "description": "Start at root (assumes logged in)"
        },
        {
          "action": "click",
          "selector": "[data-dtab='monitor']",
          "description": "Click Monitor tab"
        },
        {
          "action": "click",
          "selector": "[data-tab='cron']",
          "description": "Click Cron sub-tab"
        },
        {
          "action": "waitFor",
          "selector": ".cron-job-list, .cron-jobs-table, [data-testid='cron-job-row'], .cron-job-item",
          "description": "Wait for cron job list or table to appear"
        },
        {
          "action": "screenshot",
          "filename": "CT-02-cron-job-list-loaded.png",
          "description": "Verify cron job list has loaded with at least one entry"
        }
      ],
      "assertions": [
        {
          "type": "apiCall",
          "method": "GET",
          "endpoint": "/api/cron/jobs",
          "expectedStatus": 200,
          "description": "GET /api/cron/jobs should return 200"
        },
        {
          "type": "elementVisible",
          "selector": ".cron-job-list, .cron-jobs-table, .cron-job-item",
          "description": "Cron job list container should be visible"
        }
      ]
    },
    {
      "id": "CT-03",
      "title": "Toggle cron job on/off",
      "description": "User toggles a cron job's enabled state, which calls POST /api/cron/jobs/:id/toggle",
      "steps": [
        {
          "action": "navigate",
          "url": "/agent-monitor/",
          "description": "Start at root (assumes logged in)"
        },
        {
          "action": "click",
          "selector": "[data-dtab='monitor']",
          "description": "Click Monitor tab"
        },
        {
          "action": "click",
          "selector": "[data-tab='cron']",
          "description": "Click Cron sub-tab"
        },
        {
          "action": "waitFor",
          "selector": ".cron-job-item, .cron-job-row, [data-testid='cron-job-row']",
          "description": "Wait for at least one cron job to appear"
        },
        {
          "action": "click",
          "selector": ".cron-job-item:first-child .toggle, .cron-job-row:first-child .cron-toggle, [data-testid='cron-toggle']:first-of-type",
          "description": "Click the toggle for the first cron job"
        },
        {
          "action": "waitFor",
          "selector": ".toast, .notification, [role='alert']",
          "description": "Wait for success or error notification",
          "optional": true
        },
        {
          "action": "screenshot",
          "filename": "CT-03-cron-toggle-after.png",
          "description": "Verify cron job toggle state has changed"
        }
      ],
      "assertions": [
        {
          "type": "apiCall",
          "method": "POST",
          "endpoint": "/api/cron/jobs/:id/toggle",
          "expectedStatus": 200,
          "description": "POST /api/cron/jobs/:id/toggle should return 200"
        }
      ]
    },
    {
      "id": "CT-04",
      "title": "Run cron job manually",
      "description": "User clicks the Run button on a cron job to trigger it immediately via POST /api/cron/jobs/:id/run",
      "steps": [
        {
          "action": "navigate",
          "url": "/agent-monitor/",
          "description": "Start at root (assumes logged in)"
        },
        {
          "action": "click",
          "selector": "[data-dtab='monitor']",
          "description": "Click Monitor tab"
        },
        {
          "action": "click",
          "selector": "[data-tab='cron']",
          "description": "Click Cron sub-tab"
        },
        {
          "action": "waitFor",
          "selector": ".cron-job-item, .cron-job-row, [data-testid='cron-job-row']",
          "description": "Wait for cron job list to appear"
        },
        {
          "action": "click",
          "selector": ".cron-job-item:first-child button:has-text('Run'), .cron-job-row:first-child .cron-run-btn, [data-testid='cron-run-btn']:first-of-type",
          "description": "Click the Run button for the first cron job"
        },
        {
          "action": "waitFor",
          "selector": ".toast, .notification, [role='alert']",
          "description": "Wait for feedback notification",
          "optional": true
        },
        {
          "action": "screenshot",
          "filename": "CT-04-cron-manual-run.png",
          "description": "Verify feedback after manual run trigger"
        }
      ],
      "assertions": [
        {
          "type": "apiCall",
          "method": "POST",
          "endpoint": "/api/cron/jobs/:id/run",
          "expectedStatus": 200,
          "description": "POST /api/cron/jobs/:id/run should return 200"
        }
      ]
    },
    {
      "id": "CT-05",
      "title": "Delete cron job with confirmation",
      "description": "User clicks Delete on a cron job, confirms in the ConfirmDialog, and the job is removed via DELETE /api/cron/jobs/:id",
      "steps": [
        {
          "action": "navigate",
          "url": "/agent-monitor/",
          "description": "Start at root (assumes logged in)"
        },
        {
          "action": "click",
          "selector": "[data-dtab='monitor']",
          "description": "Click Monitor tab"
        },
        {
          "action": "click",
          "selector": "[data-tab='cron']",
          "description": "Click Cron sub-tab"
        },
        {
          "action": "waitFor",
          "selector": ".cron-job-item, .cron-job-row, [data-testid='cron-job-row']",
          "description": "Wait for cron job list to appear"
        },
        {
          "action": "click",
          "selector": ".cron-job-item:first-child button:has-text('Delete'), .cron-job-row:first-child .cron-delete-btn, [data-testid='cron-delete-btn']:first-of-type",
          "description": "Click the Delete button for the first cron job"
        },
        {
          "action": "waitFor",
          "selector": ".confirm-dialog, [role='dialog'], .modal",
          "description": "Wait for ConfirmDialog to appear"
        },
        {
          "action": "click",
          "selector": ".confirm-dialog button:has-text('Confirm'), .confirm-dialog button:has-text('Delete'), .confirm-dialog button:has-text('Yes'), [data-testid='confirm-ok']",
          "description": "Click Confirm/Delete in the ConfirmDialog"
        },
        {
          "action": "waitFor",
          "selector": ".toast, .notification, [role='alert']",
          "description": "Wait for deletion feedback",
          "optional": true
        },
        {
          "action": "screenshot",
          "filename": "CT-05-cron-delete-confirmed.png",
          "description": "Verify cron job has been removed from the list"
        }
      ],
      "assertions": [
        {
          "type": "apiCall",
          "method": "DELETE",
          "endpoint": "/api/cron/jobs/:id",
          "expectedStatus": 200,
          "description": "DELETE /api/cron/jobs/:id should return 200"
        }
      ]
    },
    {
      "id": "CT-06",
      "title": "Cancel delete confirmation",
      "description": "User clicks Delete on a cron job but cancels the ConfirmDialog — no deletion occurs",
      "steps": [
        {
          "action": "navigate",
          "url": "/agent-monitor/",
          "description": "Start at root (assumes logged in)"
        },
        {
          "action": "click",
          "selector": "[data-dtab='monitor']",
          "description": "Click Monitor tab"
        },
        {
          "action": "click",
          "selector": "[data-tab='cron']",
          "description": "Click Cron sub-tab"
        },
        {
          "action": "waitFor",
          "selector": ".cron-job-item, .cron-job-row, [data-testid='cron-job-row']",
          "description": "Wait for cron job list to appear"
        },
        {
          "action": "click",
          "selector": ".cron-job-item:first-child button:has-text('Delete'), .cron-job-row:first-child .cron-delete-btn, [data-testid='cron-delete-btn']:first-of-type",
          "description": "Click the Delete button for the first cron job"
        },
        {
          "action": "waitFor",
          "selector": ".confirm-dialog, [role='dialog'], .modal",
          "description": "Wait for ConfirmDialog to appear"
        },
        {
          "action": "click",
          "selector": ".confirm-dialog button:has-text('Cancel'), [data-testid='confirm-cancel']",
          "description": "Click Cancel in the ConfirmDialog"
        },
        {
          "action": "waitFor",
          "selector": ".confirm-dialog, [role='dialog']",
          "state": "hidden",
          "description": "ConfirmDialog should close"
        },
        {
          "action": "screenshot",
          "filename": "CT-06-cron-delete-cancelled.png",
          "description": "Verify cron job is still present and dialog is dismissed"
        }
      ],
      "assertions": [
        {
          "type": "elementVisible",
          "selector": ".cron-job-item, .cron-job-row",
          "description": "Cron job list should still contain items after cancel"
        },
        {
          "type": "elementHidden",
          "selector": ".confirm-dialog, [role='dialog']",
          "description": "ConfirmDialog should be closed"
        }
      ]
    },
    {
      "id": "CT-07",
      "title": "Empty state when no cron jobs",
