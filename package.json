{
  "name": "agent-monitor-web",
  "version": "1.0.0",
  "description": "OpenClaw Agent 監控系統 - 網頁版",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "nodemon --env-file=.env server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "node-fetch": "^2.6.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "openclaw",
    "monitor",
    "agent",
    "dashboard"
  ],
  "author": "OpenClaw Development Team",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!chokidar)"
    ],
    "transform": {
      "node_modules/chokidar/.+\\.js$": "babel-jest",
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "^chokidar$": "<rootDir>/tests/__mocks__/chokidar.js"
    },
    "collectCoverageFrom": [
      "src/backend/**/*.js"
    ]
  }
}
