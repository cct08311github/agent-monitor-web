# ============================================================
# agent-monitor-web — Environment Variables Example
# ============================================================
# Copy this file to `.env` then fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored. Never commit real secrets.
# Startup validation (src/backend/config/startup.js) will fail
# fast if required vars are missing.
# ============================================================

# ── Authentication ───────────────────────────────────────────
# Username for dashboard login (default: admin)
AUTH_USERNAME=admin

# bcrypt hash of the password — REQUIRED unless AUTH_DISABLED=true
# Generate with: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
AUTH_PASSWORD_HASH=

# Random secret for HMAC-signed session cookies (REQUIRED, min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SESSION_SECRET=

# Session TTL in hours (default: 8)
AUTH_SESSION_TTL_HOURS=8

# Disable auth entirely — DEV ONLY, never set true in production
AUTH_DISABLED=false

# ── Server ───────────────────────────────────────────────────
# HTTPS port (default: 3001)
PORT=3001

# Sub-path mount for reverse-proxy deployments (e.g. /agent-monitor)
# Leave empty to serve at root
BASE_PATH=

# Node environment — set to "production" for deployment
NODE_ENV=development

# ── Control endpoints ────────────────────────────────────────
# Bearer token for /api/control/* endpoints (REQUIRED for control ops)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HUD_CONTROL_TOKEN=

# Comma-separated extra hosts allowed for control endpoints
# (loopback + Tailscale auto-allowed; only add here for special cases)
CONTROL_ALLOWED_HOSTS=

# ── OpenClaw integration ─────────────────────────────────────
# Path to the openclaw binary (auto-detected if unset)
# OPENCLAW_BIN=/usr/local/bin/openclaw

# ── Gateway ──────────────────────────────────────────────────
# OpenClaw Gateway port (default: 18789)
GATEWAY_PORT=18789

# ── Dashboard cache TTLs (milliseconds) ──────────────────────
# Tune polling frequency vs freshness
DASHBOARD_CACHE_TTL_SYS_MS=5000
DASHBOARD_CACHE_TTL_AGENTS_MS=10000
DASHBOARD_CACHE_TTL_CRON_MS=30000
DASHBOARD_CACHE_TTL_COOLDOWNS_MS=15000
DASHBOARD_POLLING_INTERVAL_MS=15000

# ── Time-series database ─────────────────────────────────────
# Interval between metric snapshots into TSDB
TSDB_SNAPSHOT_INTERVAL_MS=60000

# ── Gateway Watchdog ─────────────────────────────────────────
# Self-heal subsystem for OpenClaw Gateway crashes
WATCHDOG_CHECK_INTERVAL_MS=30000
WATCHDOG_REPAIR_COOLDOWN_MS=180000
WATCHDOG_MAX_REPAIR_ATTEMPTS=3
WATCHDOG_HEALTH_CHECK_TIMEOUT_MS=8000
WATCHDOG_REPAIR_WAIT_MS=20000
WATCHDOG_RESTART_GRACE_PERIOD_MS=60000
WATCHDOG_GEMINI_TIMEOUT_MS=30000
WATCHDOG_TELEGRAM_COOLDOWN_MS=900000

# ── Optional integrations ────────────────────────────────────
# Gemini API key for 自主優化 pipeline (fallback: ~/.openclaw/.env)
# GEMINI_API_KEY=
